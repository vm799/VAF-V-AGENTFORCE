# VAF Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

# Telegram Bot (required for morning briefing + mobile capture)
VAF_TELEGRAM_TOKEN=your-bot-token-from-botfather
VAF_TELEGRAM_CHAT_ID=your-chat-id

# Obsidian vault path
VAF_OBSIDIAN_VAULT_DIR=/Users/yourname/Desktop/SecondBrain

# Claude/Anthropic API (required for enterprise pipeline AI features)
VAF_ANTHROPIC_KEY_1=sk-ant-...

# Enterprise knowledge source (choose one)
KB_TYPE=obsidian

# Confluence (enterprise clients)
# CONFLUENCE_URL=https://yourcompany.atlassian.net
# CONFLUENCE_SPACE=ENG
# CONFLUENCE_USER=api-user@company.com
# CONFLUENCE_TOKEN=your-api-token

# Slack (optional delivery channel)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
